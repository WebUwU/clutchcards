// Ascendant Cards — production schema.
// Local dev uses SQLite; for production set provider="postgresql" and a
// Postgres DATABASE_URL. No other code changes required.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js core models ────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user" | "admin"
  passwordHash  String?   // only set for credential/admin accounts
  createdAt     DateTime  @default(now())

  accounts        Account[]
  sessions        Session[]
  profile         Profile?
  settings        Settings?
  inventory       InventoryItem[]
  listings        MarketListing[] @relation("Seller")
  buyTransactions Transaction[]   @relation("Buyer")
  sellTransactions Transaction[]  @relation("SellerTx")
  questProgress   QuestProgress[]
  questRewards    QuestRewardClaim[]
  linkedAccounts  LinkedAccount[]
  valorantAccount ValorantAccount?
  syncedMatches   SyncedMatch[]
  auditLogs       AuditLog[]
  packOpenings    PackOpening[]
  exchanges       Exchange[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── Profile / settings ─────────────────────────────────────────────
model Profile {
  id           String  @id @default(cuid())
  userId       String  @unique
  username     String  @unique
  displayName  String  @default("")
  bio          String  @default("")
  avatar       String  @default("https://api.dicebear.com/7.x/bottts-neutral/svg?seed=clutch")
  region       String  @default("Europe")
  language     String  @default("English")
  timezone     String  @default("Europe/Vienna")
  favoriteRole String  @default("neutral")
  favoriteCategory String @default("Agent")
  level        Int     @default(1)
  xp           Int     @default(0)
  freeCoins    Int     @default(1000)
  premiumCoins Int     @default(0)
  dailyStreak  Int     @default(0)
  lastLogin    DateTime?
  isPublic     Boolean @default(true)
  showcaseCardIds String @default("[]") // JSON array of card ids
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id     String @id @default(cuid())
  userId String @unique
  json   String @default("{}") // serialized UserSettings
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Catalog: cards / sets / rarities / types / packs ───────────────
model CardSet {
  id          String  @id
  name        String
  slug        String  @unique
  description String  @default("")
  season      String  @default("")
  releaseDate DateTime @default(now())
  coverImage  String  @default("")
  accentColor String  @default("#ff4655")
  backgroundStyle String @default("radial")
  totalCards  Int     @default(0)
  isActive    Boolean @default(true)
  cards Card[]
}

model Rarity {
  id              String @id
  name            String
  sortOrder       Int    @default(0)
  color           String @default("#9aa4b2")
  glowClass       String @default("")
  dropWeight      Int    @default(100)
  minFusionRequired Int  @default(3)
  borderStyle     String @default("solid")
}

model CardType {
  id          String @id
  name        String
  description String @default("")
  icon        String @default("Shapes")
  color       String @default("#3ea6ff")
}

model Card {
  id          String  @id
  setId       String
  name        String
  slug        String  @unique
  rarityId    String
  typeId      String
  role        String  @default("neutral")
  description String  @default("")
  image       String  @default("")
  tradable    Boolean @default(true)
  fusionValue Int     @default(100)
  isLimited   Boolean @default(false)
  isAnimated  Boolean @default(false)
  isFeatured  Boolean @default(false)
  tags        String  @default("[]") // JSON array
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  set       CardSet @relation(fields: [setId], references: [id])
  inventory InventoryItem[]
  listings  MarketListing[]
}

model Pack {
  id               String  @id
  name             String
  slug             String  @unique
  description      String  @default("")
  image            String  @default("")
  priceFreeCoins   Int     @default(0)
  pricePremiumCoins Int    @default(0)
  allowedSetIds    String  @default("[]") // JSON array
  dropTable        String  @default("[]") // JSON array of {rarityId, weight}
  guaranteedRarity String?
  cardCount        Int     @default(3)
  isPremium        Boolean @default(false)
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  openings PackOpening[]
}

// ─── Inventory ──────────────────────────────────────────────────────
model InventoryItem {
  id       String @id @default(cuid())
  userId   String
  cardId   String
  amount   Int    @default(1)
  favorite Boolean @default(false)
  acquiredAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])
  @@unique([userId, cardId])
}

// ─── Market ─────────────────────────────────────────────────────────
model MarketListing {
  id         String  @id @default(cuid())
  cardId     String
  sellerId   String
  price      Int
  status     String  @default("active") // active | sold | cancelled
  createdAt  DateTime @default(now())
  card   Card @relation(fields: [cardId], references: [id])
  seller User @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id         String  @id @default(cuid())
  listingId  String?
  cardId     String
  buyerId    String
  sellerId   String
  price      Int
  fee        Int     @default(0)
  sellerNet  Int     @default(0)
  type       String  @default("market") // market | pack | exchange | reward
  createdAt  DateTime @default(now())
  listing MarketListing? @relation(fields: [listingId], references: [id])
  buyer   User @relation("Buyer", fields: [buyerId], references: [id])
  seller  User @relation("SellerTx", fields: [sellerId], references: [id])
}

// ─── Packs / exchange logs ──────────────────────────────────────────
model PackOpening {
  id            String  @id @default(cuid())
  userId        String
  packId        String
  cardIds       String  // JSON array
  highestRarity String
  openedAt      DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack Pack @relation(fields: [packId], references: [id])
}

model Exchange {
  id           String @id @default(cuid())
  userId       String
  premiumSpent Int
  freeReceived Int
  createdAt    DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Quests ─────────────────────────────────────────────────────────
model Quest {
  id              String @id
  title           String
  description     String @default("")
  period          String @default("daily") // daily | weekly | seasonal
  difficulty      String @default("easy")
  metric          String @default("matches_played") // see quest engine
  metricAgent     String?  // for agent-specific quests
  metricMap       String?  // for map-specific quests
  goal            Int    @default(1)
  rewardXp        Int     @default(0)
  rewardFreeCoins Int     @default(0)
  rewardPackId    String?
  rewardCardId    String?
  isActive        Boolean @default(true)
  progress QuestProgress[]
  claims   QuestRewardClaim[]
}

model QuestProgress {
  id        String @id @default(cuid())
  userId    String
  questId   String
  progress  Int    @default(0)
  status    String @default("active") // active | completed | claimed
  updatedAt DateTime @updatedAt
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest @relation(fields: [questId], references: [id])
  @@unique([userId, questId])
}

model QuestRewardClaim {
  id        String @id @default(cuid())
  userId    String
  questId   String
  claimedAt DateTime @default(now())
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest @relation(fields: [questId], references: [id])
  @@unique([userId, questId]) // idempotency: no double rewards
}

// ─── Account linking / Valorant ─────────────────────────────────────
model LinkedAccount {
  id        String @id @default(cuid())
  userId    String
  provider  String // "discord" | "riot"
  externalId String
  data      String @default("{}")
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, provider])
}

model ValorantAccount {
  id        String  @id @default(cuid())
  userId    String  @unique
  riotName  String
  riotTag   String
  region    String
  puuid     String?
  verified  Boolean @default(false)
  lastSync  DateTime?
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([riotName, riotTag, region])
}

model SyncedMatch {
  id         String  @id @default(cuid())
  userId     String
  matchId    String
  map        String  @default("")
  agent      String  @default("")
  won        Boolean @default(false)
  kills      Int     @default(0)
  deaths     Int     @default(0)
  assists    Int     @default(0)
  headshots  Int     @default(0)
  playedAt   DateTime @default(now())
  raw        String  @default("{}") // cached subset of match data
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, matchId]) // prevent duplicate processing
}

// ─── Ops: audit + api sync logs ─────────────────────────────────────
model AuditLog {
  id        String  @id @default(cuid())
  userId    String?
  action    String
  target    String  @default("")
  meta      String  @default("{}")
  createdAt DateTime @default(now())
  user User? @relation(fields: [userId], references: [id])
}

model ApiSyncLog {
  id        String  @id @default(cuid())
  userId    String?
  endpoint  String
  status    String
  detail    String  @default("")
  createdAt DateTime @default(now())
}

